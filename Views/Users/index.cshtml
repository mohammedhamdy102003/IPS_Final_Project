@model IPS_PROJECT.Models.ViewModels.UsersViewModel
@{
    ViewData["Title"] = "User Management - AI-Based IPS";
    ViewData["PageCss"] = "dashboard.css";
}

<style>
    /* ===== Search & Filters ===== */
    .users-search-bar {
        display: flex; align-items: center; gap: 10px;
        background: rgba(255,255,255,0.04);
        border: 1px solid rgba(255,255,255,0.06);
        border-radius: 12px; padding: 10px 14px; flex: 1;
    }
    .users-search-bar i { color: rgba(255,255,255,0.45); }
    .users-search-bar input {
        background: transparent; border: none; outline: none;
        color: rgba(255,255,255,0.86); font-size: 13px; width: 100%;
    }
    .users-search-bar input::placeholder { color: rgba(255,255,255,0.35); }
    .users-search-bar:focus-within {
        border-color: rgba(124,58,237,0.5);
        box-shadow: 0 0 0 3px rgba(124,58,237,0.12);
    }
    .role-filter-select {
        padding: 10px 14px; border-radius: 12px;
        border: 1px solid rgba(255,255,255,0.06);
        background: rgba(255,255,255,0.04);
        color: rgba(255,255,255,0.86); font-size: 13px;
        cursor: pointer; outline: none; min-width: 150px;
    }
    .user-count-badge {
        display: inline-flex; align-items: center; gap: 6px;
        background: rgba(124,58,237,0.15);
        border: 1px solid rgba(124,58,237,0.22);
        color: #c4b5fd; padding: 5px 12px;
        border-radius: 999px; font-size: 12px; font-weight: 700;
    }
    /* ===== Role Dropdown ===== */
    .role-dropdown {
        padding: 6px 10px; border-radius: 8px;
        border: 1px solid rgba(255,255,255,0.08);
        background: rgba(255,255,255,0.05);
        color: rgba(255,255,255,0.86); font-size: 12px; font-weight: 600;
        cursor: pointer; outline: none; transition: 150ms ease; min-width: 110px;
    }
    .role-dropdown.is-admin { background: rgba(124,58,237,0.18); border-color: rgba(124,58,237,0.3); color: #c4b5fd; }
    .role-dropdown.is-user  { background: rgba(59,130,246,0.14);  border-color: rgba(59,130,246,0.25);  color: #93c5fd; }
    /* ===== Status Badge ===== */
    .status-badge {
        display: inline-flex; align-items: center; gap: 6px;
        padding: 4px 10px; border-radius: 999px;
        font-size: 11px; font-weight: 800;
        letter-spacing: 0.08em; text-transform: uppercase;
    }
    .status-badge.active   { background: rgba(16,185,129,0.14); border: 1px solid rgba(16,185,129,0.22); color: rgba(16,185,129,0.95); }
    .status-badge.pending  { background: rgba(245,158,11,0.14);  border: 1px solid rgba(245,158,11,0.22);  color: rgba(245,158,11,0.95); }
    .status-badge.inactive { background: rgba(239,68,68,0.12);   border: 1px solid rgba(239,68,68,0.2);    color: rgba(239,68,68,0.9); }
    .status-badge .s-dot   { width: 6px; height: 6px; border-radius: 50%; background: currentColor; }
    /* ===== Save Role Btn ===== */
    .save-role-btn {
        padding: 6px 12px; border-radius: 8px;
        border: 1px solid rgba(16,185,129,0.3);
        background: rgba(16,185,129,0.15);
        color: rgba(16,185,129,0.95);
        font-size: 11px; font-weight: 700; cursor: pointer;
        transition: 150ms ease; white-space: nowrap;
        display: inline-flex; align-items: center; gap: 5px;
    }
    .save-role-btn:hover { background: rgba(16,185,129,0.25); }
    /* ===== Avatar ===== */
    .user-avatar {
        width: 32px; height: 32px; border-radius: 999px;
        background: rgba(124,58,237,0.2);
        border: 1px solid rgba(124,58,237,0.25);
        display: inline-flex; align-items: center; justify-content: center;
        font-size: 13px; font-weight: 700; color: #c4b5fd; flex-shrink: 0;
    }
    .user-info { display: flex; align-items: center; gap: 10px; }
    .username-text { font-weight: 650; color: rgba(255,255,255,0.88); font-size: 13px; }
    tbody tr:hover td { background: rgba(255,255,255,0.02); }
    .empty-state { text-align: center; padding: 60px 20px; color: rgba(255,255,255,0.35); }
    .empty-state i { font-size: 40px; margin-bottom: 14px; display: block; color: rgba(124,58,237,0.4); }
    /* ===== Toast ===== */
    .toast {
        position: fixed; bottom: 28px; right: 28px;
        background: #151f2c; border: 1px solid rgba(16,185,129,0.3);
        border-radius: 12px; padding: 14px 20px;
        display: flex; align-items: center; gap: 12px;
        color: rgba(255,255,255,0.88); font-size: 13px; font-weight: 600;
        box-shadow: 0 16px 40px rgba(0,0,0,0.5); z-index: 9999;
        transform: translateY(100px); opacity: 0;
        transition: all 350ms cubic-bezier(0.34, 1.56, 0.64, 1);
    }
    .toast.show { transform: translateY(0); opacity: 1; }
    /* ===== Action Buttons ===== */
    .action-btn {
        width: 30px; height: 30px; border-radius: 8px; border: none;
        cursor: pointer; display: inline-flex; align-items: center;
        justify-content: center; font-size: 12px; transition: all 150ms ease;
    }
    .btn-disable { background: rgba(245,158,11,0.12); border: 1px solid rgba(245,158,11,0.25); color: rgba(245,158,11,0.9); }
    .btn-disable:hover { background: rgba(245,158,11,0.25); }
    .btn-enable  { background: rgba(16,185,129,0.12);  border: 1px solid rgba(16,185,129,0.25);  color: rgba(16,185,129,0.9); }
    .btn-enable:hover  { background: rgba(16,185,129,0.25); }
    .btn-delete  { background: rgba(239,68,68,0.1);    border: 1px solid rgba(239,68,68,0.2);    color: rgba(239,68,68,0.85); }
    .btn-delete:hover  { background: rgba(239,68,68,0.22); }
    /* ===== Confirm Modal ===== */
    .confirm-overlay {
        position: fixed; inset: 0; background: rgba(0,0,0,0.55);
        z-index: 10000; display: flex; align-items: center; justify-content: center;
        opacity: 0; pointer-events: none; transition: opacity 200ms;
    }
    .confirm-overlay.show { opacity: 1; pointer-events: all; }
    .confirm-box {
        background: #141c2b; border: 1px solid rgba(255,255,255,0.08);
        border-radius: 16px; padding: 28px 32px; width: 360px;
        text-align: center; transform: scale(0.92); transition: transform 200ms;
    }
    .confirm-overlay.show .confirm-box { transform: scale(1); }
    .confirm-box h3 { color: white; font-size: 16px; margin-bottom: 10px; }
    .confirm-box p  { color: rgba(255,255,255,0.5); font-size: 13px; margin-bottom: 24px; }
    .confirm-btns { display: flex; gap: 10px; justify-content: center; }
    .confirm-btns button { padding: 10px 22px; border-radius: 10px; border: none; font-size: 13px; font-weight: 700; cursor: pointer; transition: 150ms; }
    .btn-cancel-confirm  { background: rgba(255,255,255,0.07); color: rgba(255,255,255,0.7); }
    .btn-cancel-confirm:hover { background: rgba(255,255,255,0.12); }
    .btn-confirm-delete  { background: rgba(239,68,68,0.85); color: white; }
    .btn-confirm-delete:hover { background: rgba(239,68,68,1); }

    /* ===== Admin Requests Section ===== */
    .ar-section {
        margin-top: 24px;
    }
    .ar-header {
        display: flex; align-items: center; gap: 12px; margin-bottom: 16px;
    }
    .ar-title {
        font-size: 16px; font-weight: 700; color: rgba(255,255,255,0.9);
    }
    .ar-badge {
        display: inline-flex; align-items: center; justify-content: center;
        background: rgba(245,158,11,0.2); border: 1px solid rgba(245,158,11,0.35);
        color: rgba(245,158,11,0.95); border-radius: 999px;
        font-size: 11px; font-weight: 800; min-width: 22px; height: 22px; padding: 0 7px;
    }
    .ar-empty {
        text-align: center; padding: 40px 20px;
        color: rgba(255,255,255,0.3); font-size: 13px;
    }
    .ar-empty i { font-size: 28px; display: block; margin-bottom: 10px; color: rgba(255,255,255,0.12); }
    /* Request Card */
    .ar-card {
        display: flex; align-items: center; justify-content: space-between;
        background: rgba(255,255,255,0.03);
        border: 1px solid rgba(255,255,255,0.06);
        border-radius: 12px; padding: 14px 18px;
        margin-bottom: 10px; gap: 16px;
        transition: background 150ms;
    }
    .ar-card:hover { background: rgba(255,255,255,0.05); }
    .ar-card:last-child { margin-bottom: 0; }
    .ar-user { display: flex; align-items: center; gap: 12px; flex: 1; }
    .ar-avatar {
        width: 38px; height: 38px; border-radius: 999px;
        background: rgba(245,158,11,0.15);
        border: 1px solid rgba(245,158,11,0.3);
        display: flex; align-items: center; justify-content: center;
        font-size: 14px; font-weight: 800; color: rgba(245,158,11,0.9);
        flex-shrink: 0;
    }
    .ar-name { font-size: 14px; font-weight: 700; color: rgba(255,255,255,0.9); margin-bottom: 2px; }
    .ar-email { font-size: 12px; color: rgba(255,255,255,0.4); }
    .ar-date { font-size: 11px; color: rgba(255,255,255,0.3); white-space: nowrap; }
    .ar-actions { display: flex; gap: 8px; align-items: center; }
    /* Approve / Reject icon buttons */
    .ar-btn {
        width: 36px; height: 36px; border-radius: 10px; border: none;
        cursor: pointer; display: flex; align-items: center; justify-content: center;
        font-size: 15px; font-weight: 800; transition: all 150ms; text-decoration: none;
    }
    .ar-btn-approve {
        background: rgba(16,185,129,0.15);
        border: 1.5px solid rgba(16,185,129,0.35);
        color: rgba(16,185,129,0.95);
    }
    .ar-btn-approve:hover {
        background: rgba(16,185,129,0.3);
        transform: scale(1.08);
        color: rgba(16,185,129,1);
    }
    .ar-btn-reject {
        background: rgba(239,68,68,0.12);
        border: 1.5px solid rgba(239,68,68,0.25);
        color: rgba(239,68,68,0.85);
    }
    .ar-btn-reject:hover {
        background: rgba(239,68,68,0.25);
        transform: scale(1.08);
        color: rgba(239,68,68,1);
    }
    /* Tooltip */
    .ar-btn[title] { position: relative; }
</style>

<body>
    <div class="app">
        <aside class="sidebar">
            <div class="brand">
                <div class="brand-badge" aria-hidden="true"><i class="fa-solid fa-shield"></i></div>
                <div class="brand-title">AI-Based IPS</div>
            </div>
            <nav class="nav" aria-label="Sidebar">
                <a href="/Dashboard"><i class="fa-solid fa-table-cells"></i>Overview</a>
                <a class="active" href="/Users" aria-current="page"><i class="fa-solid fa-users"></i>Users</a>
            </nav>
            <div class="sidebar-footer">SYSTEM v3.6.1</div>
        </aside>

        <main class="main">
            <header class="topbar">
                <div class="search" role="search">
                    <i class="fa-solid fa-magnifying-glass" aria-hidden="true"></i>
                    <input type="text" placeholder="Global search for threats, IPs, or logs..." aria-label="Global search" />
                </div>
                <div class="top-actions">
                    <div class="segmented" role="tablist" aria-label="View mode">
                        <button class="active" id="adminViewBtn" role="tab" aria-selected="true" type="button">Admin View</button>
                        <button id="userViewBtn" role="tab" aria-selected="false" type="button">User View</button>
                    </div>
                    <div class="avatar" aria-label="User menu"><i class="fa-regular fa-user"></i></div>
                </div>
            </header>

            <div class="content">
                <div class="page-head">
                    <div>
                        <h1 class="page-title">User Management</h1>
                        <p class="page-subtitle">Manage registered users and control their roles and permissions</p>
                    </div>
                    <div class="head-actions">
                        <span class="user-count-badge">
                            <i class="fa-solid fa-users"></i>
                            <span>@(Model?.Users?.Count() ?? 0) Users</span>
                        </span>
                    </div>
                </div>

                <!-- ===== Registered Users Table ===== -->
                <section class="card table-card" aria-label="Users list">
                    <div class="table-head" style="flex-direction: column; align-items: flex-start; gap: 14px;">
                        <div class="table-title">Registered Users</div>
                        <form method="get" asp-action="Index" asp-controller="Users"
                              style="display: flex; align-items: center; gap: 12px; width: 100%;">
                            <div class="users-search-bar">
                                <i class="fa-solid fa-magnifying-glass"></i>
                                <input name="search" type="text" placeholder="Search by username or email..." />
                            </div>
                            <select name="roleFilter" class="role-filter-select" onchange="this.form.submit()">
                                <option value="">All Roles</option>
                                <option value="Admin">Admin</option>
                                <option value="User">User</option>
                            </select>
                            <select name="statusFilter" class="role-filter-select" onchange="this.form.submit()">
                                <option value="">All Status</option>
                                <option value="Active">Active</option>
                                <option value="Pending">Pending</option>
                                <option value="Inactive">Inactive</option>
                            </select>
                            <button type="submit"
                                    style="padding: 10px 22px; border-radius: 12px;
                                           background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.1);
                                           color: rgba(255,255,255,0.86); font-weight: 700; font-size: 14px;
                                           cursor: pointer; white-space: nowrap;">
                                Search
                            </button>
                        </form>
                    </div>

                    <div style="overflow: auto;">
                        <table>
                            <thead>
                                <tr>
                                    <th>USERNAME</th><th>EMAIL</th><th>ROLE</th>
                                    <th>STATUS</th><th>CREATED DATE</th><th>ACTIONS</th>
                                </tr>
                            </thead>
                            <tbody id="usersBody">
                                @if (Model?.Users != null && Model.Users.Any())
                                {
                                    @foreach (var user in Model.Users)
                                    {
                                        <tr>
                                            <td>
                                                <div class="user-info">
                                                    <div class="user-avatar">
                                                        @(user.UserName?.Length > 0 ? user.UserName[0].ToString().ToUpper() : "U")
                                                    </div>
                                                    <span class="username-text">@user.UserName</span>
                                                </div>
                                            </td>
                                            <td class="dim" style="font-size:13px;">@user.Email</td>
                                            <td>
                                      @{
    var adminSelected = user.Role == "Admin" ? "selected" : null;
    var userSelected  = user.Role != "Admin" ? "selected" : null;
}
<select class="role-dropdown @(user.Role == "Admin" ? "is-admin" : "is-user")"
        id="role-@user.Id"
        onchange="onRoleChange(this, '@user.Id')">
  <option value="Admin" selected="@(user.Role == "Admin")">👑 Admin</option>
<option value="User"  selected="@(user.Role != "Admin")">👤 User</option>
</select>
                                            </td>
                                            <td>
                                                @if (user.Status == "Active")
                                                { <span class="status-badge active"><span class="s-dot"></span> Active</span> }
                                                else if (user.Status == "Pending")
                                                { <span class="status-badge pending"><span class="s-dot"></span> Pending</span> }
                                                else
                                                { <span class="status-badge inactive"><span class="s-dot"></span> Inactive</span> }
                                            </td>
                                            <td class="mono dim" style="font-size:12px;">
                                                @user.CreatedAt.ToString("MM/dd/yyyy hh:mm tt")
                                            </td>
                                            <td>
                                                <div style="display:flex; align-items:center; gap:6px; flex-wrap:wrap;">
                                                    <button class="save-role-btn" id="save-@user.Id"
                                                            onclick="saveRole('@user.Id')" style="display:none;">
                                                        <i class="fa-solid fa-check"></i> Save
                                                    </button>
                                                    <span class="dim" id="saved-@user.Id" style="font-size:12px; display:none;">—</span>

                                                    <button class="action-btn @(user.Status == "Inactive" ? "btn-enable" : "btn-disable")"
                                                            id="disable-@user.Id"
                                                            onclick="toggleDisable('@user.Id', this)"
                                                            title="@(user.Status == "Inactive" ? "Enable User" : "Disable User")">
                                                        <i class="fa-solid @(user.Status == "Inactive" ? "fa-lock-open" : "fa-ban")"></i>
                                                    </button>

                                                    <button class="action-btn btn-delete"
                                                            onclick="deleteUser('@user.Id', '@user.UserName')"
                                                            title="Delete User">
                                                        <i class="fa-solid fa-trash"></i>
                                                    </button>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="6">
                                            <div class="empty-state">
                                                <i class="fa-solid fa-users-slash"></i>
                                                <div style="font-size:15px;font-weight:700;color:rgba(255,255,255,0.55);margin-bottom:6px;">No users found</div>
                                                <div style="font-size:13px;">Try adjusting your search or filters</div>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    <div class="table-foot">
                        <div>Showing @(Model?.Users?.Count() ?? 0) users</div>
                        <div class="pager" aria-label="Pagination">
                            <span class="link">Previous</span>
                            <span class="page active">1</span>
                            <span class="link">Next</span>
                        </div>
                    </div>
                </section>

                <!-- ===== Admin Requests Section ===== -->
                <section class="card ar-section" aria-label="Admin access requests">
                    <div class="ar-header">
                        <i class="fa-solid fa-user-shield" style="color: rgba(245,158,11,0.8); font-size:18px;"></i>
                        <span class="ar-title">Admin Access Requests</span>
                        @{
                            int reqCount = Model?.PendingAdminRequests?.Count() ?? 0;
                        }
                        @if (reqCount > 0)
                        {
                            <span class="ar-badge">@reqCount</span>
                        }
                    </div>

                    @if (Model?.PendingAdminRequests != null && Model.PendingAdminRequests.Any())
                    {
                        foreach (var p in Model.PendingAdminRequests)
                        {
                            <div class="ar-card" id="ar-card-@p.UserId">
                                <div class="ar-user">
                                    <div class="ar-avatar">
                                        @(p.User?.FullName?.Length > 0 ? p.User.FullName[0].ToString().ToUpper() : "?")
                                    </div>
                                    <div>
                                        <div class="ar-name">@p.User?.FullName</div>
                                        <div class="ar-email">@p.User?.Email</div>
                                    </div>
                                </div>
                                <div class="ar-date">
                                    <i class="fa-regular fa-clock" style="margin-right:4px;"></i>
                                    @p.RequestDate.ToString("MMM dd, yyyy • hh:mm tt")
                                </div>
                                <div class="ar-actions">
                                    <!-- Approve -->
                                    <a href="@Url.Action("ApproveAdminDashboard", "Account", new { userId = p.UserId })"
                                       class="ar-btn ar-btn-approve"
                                       title="Approve – Grant admin access"
                                       onclick="return confirmAction(event, 'approve', '@p.UserId', '@p.User?.FullName')">
                                        <i class="fa-solid fa-check"></i>
                                    </a>
                                    <!-- Reject -->
                                    <a href="@Url.Action("RejectAdminDashboard", "Account", new { userId = p.UserId })"
                                       class="ar-btn ar-btn-reject"
                                       title="Reject – Deny admin access"
                                       onclick="return confirmAction(event, 'reject', '@p.UserId', '@p.User?.FullName')">
                                        <i class="fa-solid fa-xmark"></i>
                                    </a>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="ar-empty">
                            <i class="fa-solid fa-inbox"></i>
                            No pending admin requests
                        </div>
                    }
                </section>

            </div><!-- end content -->

            <footer class="footer">
                <div>© 2023 Enterprise Cybersecurity Solutions Inc. All rights reserved.</div>
                <div class="footer-links">
                    <a href="#">Terms of Service</a>
                    <a href="#">Privacy Policy</a>
                    <a href="#">Support</a>
                </div>
            </footer>
        </main>
    </div>

    <!-- ===== Toast ===== -->
    <div class="toast" id="toast">
        <i class="fa-solid fa-circle-check" id="toastIcon"></i>
        <span id="toastMsg">Done</span>
    </div>

    <!-- ===== Confirm Delete Modal ===== -->
    <div class="confirm-overlay" id="confirmOverlay">
        <div class="confirm-box">
            <h3>🗑️ Delete User</h3>
            <p>Are you sure you want to delete <strong id="deleteUserName"></strong>? This action cannot be undone.</p>
            <div class="confirm-btns">
                <button class="btn-cancel-confirm" id="cancelDelete">Cancel</button>
                <button class="btn-confirm-delete" id="confirmDelete">Yes, Delete</button>
            </div>
        </div>
    </div>

    <!-- ===== Admin Request Confirm Modal ===== -->
    <div class="confirm-overlay" id="arConfirmOverlay">
        <div class="confirm-box">
            <h3 id="arModalTitle">Confirm Action</h3>
            <p id="arModalBody">Are you sure?</p>
            <div class="confirm-btns">
                <button class="btn-cancel-confirm" id="arCancelBtn">Cancel</button>
                <button id="arConfirmBtn" style="padding:10px 22px;border-radius:10px;border:none;font-size:13px;font-weight:700;cursor:pointer;">Confirm</button>
            </div>
        </div>
    </div>

    <script>
        /* ── Role ── */
        function onRoleChange(select, userId) {
            const saveBtn = document.getElementById('save-' + userId);
            const savedLabel = document.getElementById('saved-' + userId);
            select.className = 'role-dropdown ' + (select.value === 'Admin' ? 'is-admin' : 'is-user');
            saveBtn.style.display = 'inline-flex';
            savedLabel.style.display = 'none';
        }

        async function saveRole(userId) {
            const select = document.getElementById('role-' + userId);
            const saveBtn = document.getElementById('save-' + userId);
            const savedLabel = document.getElementById('saved-' + userId);
            saveBtn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Saving...';
            saveBtn.disabled = true;
            try {
                const res = await fetch('/Users/UpdateRole', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ userId, role: select.value })
                });
                if (res.ok) {
                    saveBtn.style.display = 'none';
                    savedLabel.style.display = 'inline';
                    savedLabel.innerHTML = '<i class="fa-solid fa-check" style="color:rgba(16,185,129,0.9)"></i>';
                    showToast('Role updated to ' + select.value + ' successfully');
                } else { throw new Error(); }
            } catch {
                saveBtn.innerHTML = '<i class="fa-solid fa-check"></i> Save';
                saveBtn.disabled = false;
                showToast('Failed to update role.', true);
            }
        }

        /* ── Toggle Disable ── */
        async function toggleDisable(userId, btn) {
            try {
                const res = await fetch('/Users/ToggleDisable', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ userId })
                });
                if (res.ok) {
                    const data = await res.json();
                    const isInactive = data.status === 'Inactive';
                    btn.className = 'action-btn ' + (isInactive ? 'btn-enable' : 'btn-disable');
                    btn.title = isInactive ? 'Enable User' : 'Disable User';
                    btn.innerHTML = '<i class="fa-solid ' + (isInactive ? 'fa-lock-open' : 'fa-ban') + '"></i>';
                    const statusCell = btn.closest('tr').querySelector('.status-badge');
                    if (statusCell) {
                        statusCell.className = 'status-badge ' + (isInactive ? 'inactive' : 'active');
                        statusCell.innerHTML = '<span class="s-dot"></span> ' + data.status;
                    }
                    showToast('User ' + (isInactive ? 'disabled' : 'enabled') + ' successfully');
                } else { showToast('Failed to update status.', true); }
            } catch { showToast('Error. Try again.', true); }
        }

        /* ── Delete ── */
        let pendingDeleteId = null;

        function deleteUser(userId, username) {
            pendingDeleteId = userId;
            document.getElementById('deleteUserName').textContent = username;
            document.getElementById('confirmOverlay').classList.add('show');
        }

        document.getElementById('cancelDelete').onclick = function () {
            document.getElementById('confirmOverlay').classList.remove('show');
            pendingDeleteId = null;
        };

        document.getElementById('confirmDelete').onclick = async function () {
            if (!pendingDeleteId) return;
            document.getElementById('confirmOverlay').classList.remove('show');
            try {
                const res = await fetch('/Users/DeleteUser', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ userId: pendingDeleteId })
                });
                if (res.ok) {
                    const btn = document.getElementById('disable-' + pendingDeleteId);
                    if (btn) btn.closest('tr').remove();
                    showToast('User deleted successfully');
                } else { showToast('Failed to delete user.', true); }
            } catch { showToast('Error. Try again.', true); }
            pendingDeleteId = null;
        };

        /* ── Admin Request Confirm ── */
        let pendingArUrl = null;

        function confirmAction(e, type, userId, name) {
            e.preventDefault();
            pendingArUrl = e.currentTarget.href;
            const isApprove = type === 'approve';
            document.getElementById('arModalTitle').textContent = isApprove ? '✅ Approve Admin Request' : '❌ Reject Admin Request';
            document.getElementById('arModalBody').textContent =
                isApprove
                    ? `Grant admin access to "${name}"? They will be promoted from User to Admin.`
                    : `Reject the admin request from "${name}"? Their account will remain as a regular User.`;
            const confirmBtn = document.getElementById('arConfirmBtn');
            confirmBtn.style.background = isApprove ? 'rgba(16,185,129,0.85)' : 'rgba(239,68,68,0.85)';
            confirmBtn.style.color = 'white';
            confirmBtn.textContent = isApprove ? 'Yes, Approve' : 'Yes, Reject';
            document.getElementById('arConfirmOverlay').classList.add('show');
            return false;
        }

        document.getElementById('arCancelBtn').onclick = function () {
            document.getElementById('arConfirmOverlay').classList.remove('show');
            pendingArUrl = null;
        };

        document.getElementById('arConfirmBtn').onclick = function () {
            if (pendingArUrl) window.location.href = pendingArUrl;
        };

        /* ── Toast ── */
        function showToast(msg, isError = false) {
            const toast = document.getElementById('toast');
            const icon  = document.getElementById('toastIcon');
            toast.style.borderColor = isError ? 'rgba(239,68,68,0.3)' : 'rgba(16,185,129,0.3)';
            icon.style.color = isError ? 'rgba(239,68,68,0.9)' : 'rgba(16,185,129,0.9)';
            icon.className = isError ? 'fa-solid fa-circle-xmark' : 'fa-solid fa-circle-check';
            document.getElementById('toastMsg').textContent = msg;
            toast.classList.add('show');
            setTimeout(() => toast.classList.remove('show'), 3000);
        }
    </script>
</body>
