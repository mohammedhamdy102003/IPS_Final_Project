@{
    ViewData["Title"] = "Verify Email - AI-Based IPS";
}

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&display=swap" rel="stylesheet">

<style>
    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
        font-family: 'Inter', sans-serif;
        background: #f0f2f5;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 20px;
    }

    .brand {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 28px;
    }

    .brand-icon {
        width: 44px;
        height: 44px;
        background: linear-gradient(135deg, #4f46e5, #7c3aed);
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-size: 20px;
    }

    .brand-text h2 {
        font-size: 16px;
        font-weight: 700;
        color: #111827;
    }

    .brand-text p {
        font-size: 12px;
        color: #6b7280;
    }

    .card {
        background: white;
        border-radius: 20px;
        padding: 44px 48px;
        width: 100%;
        max-width: 460px;
        box-shadow: 0 4px 24px rgba(0,0,0,0.08);
        text-align: center;
    }

    .email-icon {
        width: 64px;
        height: 64px;
        background: linear-gradient(135deg, rgba(79,70,229,0.1), rgba(124,58,237,0.1));
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 24px;
        font-size: 28px;
    }

    .card h1 {
        font-size: 22px;
        font-weight: 700;
        color: #111827;
        margin-bottom: 12px;
    }

    .card .subtitle {
        font-size: 14px;
        color: #6b7280;
        line-height: 1.6;
        margin-bottom: 32px;
    }

    .card .subtitle strong {
        color: #4f46e5;
    }

    .divider {
        height: 1px;
        background: #f3f4f6;
        margin: 24px 0;
    }

    .resend-section p {
        font-size: 13px;
        color: #9ca3af;
        margin-bottom: 14px;
    }

    .btn-resend {
        width: 100%;
        padding: 13px;
        border-radius: 12px;
        border: none;
        background: linear-gradient(135deg, #4f46e5, #7c3aed);
        color: white;
        font-size: 14px;
        font-weight: 600;
        cursor: pointer;
        transition: opacity 0.2s, transform 0.2s;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        text-decoration: none;
    }

    .btn-resend:hover {
        opacity: 0.9;
        transform: translateY(-1px);
    }

    .back-link {
        display: block;
        margin-top: 20px;
        font-size: 13px;
        color: #9ca3af;
        text-decoration: none;
    }

    .back-link a {
        color: #4f46e5;
        font-weight: 600;
        text-decoration: none;
    }

    .back-link a:hover { text-decoration: underline; }

    .alert-success {
        background: rgba(16,185,129,0.08);
        border: 1px solid rgba(16,185,129,0.25);
        border-radius: 10px;
        padding: 12px 16px;
        color: #065f46;
        font-size: 13px;
        font-weight: 600;
        margin-bottom: 20px;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .steps {
        text-align: left;
        background: #f9fafb;
        border-radius: 12px;
        padding: 16px 20px;
        margin-bottom: 24px;
    }

    .steps p {
        font-size: 12px;
        color: #6b7280;
        font-weight: 600;
        margin-bottom: 10px;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    .step {
        display: flex;
        align-items: flex-start;
        gap: 10px;
        margin-bottom: 8px;
        font-size: 13px;
        color: #374151;
    }

    .step:last-child { margin-bottom: 0; }

    .step-num {
        width: 20px;
        height: 20px;
        border-radius: 50%;
        background: #4f46e5;
        color: white;
        font-size: 11px;
        font-weight: 700;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        margin-top: 1px;
    }
</style>

<div class="brand">
    <div class="brand-icon">🛡️</div>
    <div class="brand-text">
        <h2>AI-Based IPS</h2>
        <p>Intrusion Prevention System</p>
    </div>
</div>

<div class="card">
    <div class="email-icon">📧</div>
    <h1>Check Your Email</h1>
    <p class="subtitle">
        We've sent a confirmation link to your inbox.<br>
        Click the link to activate your account.
    </p>

    @if (TempData["StatusMessage"] != null)
    {
        <div class="alert-success">
            ✅ @TempData["StatusMessage"]
        </div>
    }

    <div class="steps">
        <p>What to do next</p>
        <div class="step">
            <div class="step-num">1</div>
            <span>Open your email inbox</span>
        </div>
        <div class="step">
            <div class="step-num">2</div>
            <span>Find the email from <strong>IPS TEAM</strong></span>
        </div>
        <div class="step">
            <div class="step-num">3</div>
            <span>Click the <strong>"clicking here"</strong> confirmation link</span>
        </div>
        <div class="step">
            <div class="step-num">4</div>
            <span>Check spam folder if you don't see it</span>
        </div>
    </div>

    <div class="divider"></div>

    <div class="resend-section">
        <p>Didn't receive the email?</p>
        <form asp-action="ResendConfirmationEmail" method="post">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn-resend">
                🔁 Resend Confirmation Email
            </button>
        </form>
    </div>

    <span class="back-link">
        Remember your password? <a asp-controller="Account" asp-action="Login">Back to Sign in</a>
    </span>
</div>
